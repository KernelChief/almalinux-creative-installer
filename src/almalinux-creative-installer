    # ---------------- Repo probing (UNPRIVILEGED) ----------------
    def _dnf_enabled_repo_ids(self):
        """
        Returns a set of enabled repo IDs by parsing:
          dnf -q repolist --enabled
        No root needed.
        """
        try:
            proc = subprocess.run(
                ["dnf", "repolist", "--enabled"],
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                text=True,
                check=False,
                timeout=8,
            )
            if proc.returncode == 0:
                out = proc.stdout.splitlines()
            else:
                out = []
        except subprocess.TimeoutExpired:
            self._run_ui(self.append_log, "⚠️ dnf repolist timed out; falling back to repo files.\n")
            out = []
        except Exception:
            out = []

        repos = set()
        for ln in out:
            ln = ln.strip()
            if not ln:
                continue
            low = ln.lower()
            if low.startswith("repo id") or low.startswith("repolist:"):
                continue
            parts = ln.split()
            if parts:
                repos.add(parts[0].strip().lower())

        if repos:
            return repos

        return self._repo_files_enabled_ids()

    def _repo_files_enabled_ids(self):
        repos = set()
        repo_dir = Path("/etc/yum.repos.d")
        if not repo_dir.exists():
            return repos

        import configparser

        for repo_file in repo_dir.glob("*.repo"):
            parser = configparser.ConfigParser(interpolation=None, strict=False)
            try:
                parser.read(repo_file)
            except Exception:
                continue
            for section in parser.sections():
                enabled = parser.get(section, "enabled", fallback="1").strip()
                if enabled in ("1", "yes", "true", "on"):
                    repos.add(section.lower())
        return repos

    def _detect_crb(self, repos):
        for r in repos:
            if r == "crb" or r.startswith("crb"):
                return True
        for r in repos:
            if r == "powertools" or r.startswith("powertools"):
                return True
        return False

    def _detect_epel(self, repos):
        for r in repos:
            if r == "epel" or r.startswith("epel"):
                return True
        return False

    def _set_requirement_state(self, key, state):
        w = self.repo_widgets.get(key)
        if not w:
            return
        if state is None:
            w["icon"].setText("…")
            w["status"].setText("Checking…")
            w["button"].setEnabled(False)
        elif state is True:
            w["icon"].setText("✅")
            w["status"].setText("Enabled")
            w["button"].setEnabled(False)
        else:
            w["icon"].setText("❌")
            w["status"].setText("Not enabled")
            w["button"].setEnabled(True)

    def _run_ui(self, func, *args, **kwargs):
        self.dispatcher.dispatch.emit(partial(func, *args, **kwargs))

    def refresh_repo_state(self):
        self._set_requirement_state("CRB", None)
        self._set_requirement_state("EPEL", None)

        def worker():
            repos = self._dnf_enabled_repo_ids()
            crb = self._detect_crb(repos)
            epel = self._detect_epel(repos)

            self._run_ui(self._set_requirement_state, "CRB", crb)
            self._run_ui(self._set_requirement_state, "EPEL", epel)
            if repos:
                repo_list = ", ".join(sorted(repos))
                self._run_ui(self.append_log, f"✅ Requirements refreshed ({repo_list})\n")
            else:
                self._run_ui(self.append_log, "⚠️ Requirements refresh found no enabled repos.\n")

        threading.Thread(target=worker, daemon=True).start()

    def show_enabled_repos_debug(self):
        def worker():
            try:
                proc = subprocess.run(
                    ["dnf", "repolist", "--enabled"],
                    stdout=subprocess.PIPE,
                    stderr=subprocess.STDOUT,
                    text=True,
                    check=False,
                )
                self._run_ui(self.append_log, "\n$ dnf repolist --enabled\n")
                self._run_ui(self.append_log, proc.stdout + "\n")
            except Exception as e:
                self._run_ui(self.append_log, f"❌ ERROR: {e}\n")

        threading.Thread(target=worker, daemon=True).start()

    # ---------------- App status (no pkexec) ----------------
    def refresh_app_state(self, app_id):
        w = self.app_widgets.get(app_id)
        if not w:
            return
        app = w["app"]

        if app["type"] == "resolve":
            installed = self._resolve_installed()
            if installed:
                w["status"].setText("✅ Installed")
                w["install"].setEnabled(False)
                w["remove"].setEnabled(True)
            else:
                w["status"].setText("ℹ️ Guided install")
                w["install"].setEnabled(True)
                w["remove"].setEnabled(False)
            return

        if app["type"] == "dnf":
            installed = subprocess.run(
                ["rpm", "-q", app["pkg"]],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            ).returncode == 0

        elif app["type"] == "flatpak":
            if not shutil.which("flatpak"):
                w["status"].setText("ℹ️ Flatpak not installed")
                w["install"].setEnabled(True)
                w["remove"].setEnabled(False)
                return

            installed = subprocess.run(
                ["flatpak", "info", "--system", app["appid"]],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            ).returncode == 0
        else:
            installed = False

        if installed:
            w["status"].setText("✅ Installed")
            w["install"].setEnabled(False)
            w["remove"].setEnabled(True)
        else:
            w["status"].setText("❌ Not installed")
            w["install"].setEnabled(True)
            w["remove"].setEnabled(False)

    # ---------------- Install/remove actions with spinner ----------------
    def install_app(self, app_id):
        w = self.app_widgets.get(app_id)
        if not w or w.get("busy"):
            return

        app = w["app"]
        if app["type"] == "dnf":
            args = ["install_pkg", app["pkg"]]
        elif app["type"] == "flatpak":
            args = ["install_flatpak_app", app["appid"]]
        else:
            return

        self.set_app_busy(app_id, True, "Installing…")
        self.run_helper_with_callback(args, on_success=lambda: self._finish_app_action(app_id))

    def remove_app(self, app_id):
        w = self.app_widgets.get(app_id)
        if not w or w.get("busy"):
            return

        app = w["app"]
        if app["type"] == "dnf":
            args = ["remove_pkg", app["pkg"]]
        else:
            return

        self.set_app_busy(app_id, True, "Removing…")
        self.run_helper_with_callback(args, on_success=lambda: self._finish_app_action(app_id))

    def _finish_app_action(self, app_id):
        self.set_app_busy(app_id, False)
        self.refresh_app_state(app_id)

    # ---------------- Krita removal prompt (with spinner) ----------------
    def confirm_remove_krita(self):
        w = self.app_widgets.get("krita")
        if w and w.get("busy"):
            return

        dialog = QMessageBox(self)
        dialog.setIcon(QMessageBox.Warning)
        dialog.setWindowTitle("Remove Krita?")
        dialog.setText("Remove Krita?")
        dialog.setInformativeText(
            "This will remove Krita.\n\n"
            "Optionally, you can also remove Flatpak + Flathub (system-wide). "
            "Only do that if you’re sure you don’t need Flatpak for anything else."
        )
        dialog.setStandardButtons(QMessageBox.Cancel)
        remove_button = dialog.addButton("Remove Krita", QMessageBox.AcceptRole)

        checkbox = QCheckBox("Also remove Flatpak + Flathub (system-wide)")
        checkbox.setChecked(False)
        dialog.setCheckBox(checkbox)

        dialog.exec()

        if dialog.clickedButton() == remove_button:
            remove_flatpak_too = checkbox.isChecked()
            self.set_app_busy("krita", True, "Removing…")

            def after_krita():
                self.set_app_busy("krita", False)
                self.refresh_app_state("krita")

            self.run_helper_with_callback(["remove_flatpak_app", "org.kde.krita"], on_success=after_krita)

            if remove_flatpak_too:
                self.run_helper_with_callback(["remove_flatpak_and_flathub"], on_success=self.refresh_all_states)

    # ---------------- Helper runner (PRIVILEGED) ----------------
    def run_helper_with_callback(self, args, on_success=None):
        if not Path(HELPER).exists():
            self.append_log("❌ ERROR: Helper not found: " + HELPER + "\n")
            return

        self._log_polkit_check()

        cmd = ["pkexec", HELPER] + args
        self.append_log("\n$ " + " ".join(cmd) + "\n")

        def worker():
            last_lines = deque(maxlen=40)

            def summarize_failure(rc):
                for line in reversed(last_lines):
                    s = line.strip()
                    if s:
                        return s
                return "Exit code {}".format(rc)

            try:
                proc = subprocess.Popen(
                    cmd,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.STDOUT,
                    text=True,
                    bufsize=1,
                )
                assert proc.stdout is not None

                for line in proc.stdout:
                    last_lines.append(line)
                    self._run_ui(self.append_log, line)

                rc = proc.wait()

                if rc == 0:
                    self._run_ui(self.append_log, "✅ Successful\n")
                    self._run_ui(self.append_log, "[exit code: {}]\n".format(rc))
                    if on_success:
                        self._run_ui(on_success)
                else:
                    reason = summarize_failure(rc)
                    self._run_ui(self.append_log, "❌ Failed: {}\n".format(reason))
                    self._run_ui(self.append_log, "[exit code: {}]\n".format(rc))
                    self._run_ui(self._stop_all_busy)

            except Exception as e:
                self._run_ui(self.append_log, "❌ ERROR: {}\n".format(e))
                self._run_ui(self._stop_all_busy)

        threading.Thread(target=worker, daemon=True).start()

    def _log_polkit_check(self):
        try:
            proc = subprocess.run(
                ["pkcheck", "--action-id", POLKIT_ACTION_ID],
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                check=False,
            )
            if proc.returncode != 0:
                self.append_log(
                    "⚠️ Polkit check failed for action {} (rc={}). Output:\n{}\n".format(
                        POLKIT_ACTION_ID,
                        proc.returncode,
                        proc.stdout.strip() or "(no output)",
                    )
                )
        except Exception as e:
            self.append_log(f"⚠️ Polkit check error: {e}\n")

    def _stop_all_busy(self):
        for app_id in list(self.app_widgets.keys()):
            w = self.app_widgets[app_id]
            if w.get("busy"):
                self.set_app_busy(app_id, False)
                self.refresh_app_state(app_id)

    # ---------------- DaVinci Resolve flow ----------------
    def install_resolve_flow(self):
        self._ensure_selinux_for_resolve()

    def _selinux_getenforce(self):
        try:
            proc = subprocess.run(
                ["getenforce"],
                stdout=subprocess.PIPE,
                stderr=subprocess.DEVNULL,
                text=True,
                check=False,
            )
            out = proc.stdout.strip().lower()
            if out:
                return out
        except Exception:
            pass
        return "unknown"

    def _ensure_selinux_for_resolve(self):
        mode = self._selinux_getenforce()
        if mode in ("permissive", "disabled"):
            self.run_helper_with_callback(["prepare_resolve_deps"], on_success=self._resolve_open_and_pick)
            return

        dialog = QMessageBox(self)
        dialog.setIcon(QMessageBox.Warning)
        dialog.setWindowTitle("DaVinci Resolve requires SELinux permissive or disabled.")
        dialog.setText("DaVinci Resolve requires SELinux permissive or disabled.")
        dialog.setInformativeText(
            "Choose how you want to proceed before installing Resolve.\n\n"
            "A reboot is required for the SELinux change to be fully applied "
            "before launching DaVinci Resolve."
        )
        cancel_button = dialog.addButton("Cancel", QMessageBox.RejectRole)
        permissive_button = dialog.addButton("Permissive (permanent)", QMessageBox.ApplyRole)
        disable_button = dialog.addButton("Disable SELinux (permanent)", QMessageBox.YesRole)
        dialog.exec()

        if dialog.clickedButton() == cancel_button:
            return
        if dialog.clickedButton() == permissive_button:
            mode_arg = "permissive"
        else:
            mode_arg = "disabled"

        self.run_helper_with_callback(
            ["set_selinux_mode", mode_arg],
            on_success=lambda: self.run_helper_with_callback(
                ["prepare_resolve_deps"],
                on_success=self._resolve_open_and_pick
            )
        )

    def _resolve_open_and_pick(self):
        if shutil.which("xdg-open"):
            subprocess.Popen(["xdg-open", RESOLVE_URL])
            self.append_log(f"Opened download page: {RESOLVE_URL}\n")
        else:
            self.append_log(f"Please open this URL manually: {RESOLVE_URL}\n")

        self.pick_resolve_installer()

    def pick_resolve_installer(self):
        path, _filter = QFileDialog.getOpenFileName(
            self,
            "Select DaVinci Resolve installer (.run preferred)",
            "",
            "Installers (*.run *.rpm);;All Files (*)",
        )
        if path:
            if path.endswith(".run"):
                self.run_local_run_installer(path)
            else:
                self.run_helper_with_callback(["install_local_file", path],
                                              on_success=lambda: self.refresh_app_state("resolve"))

    def _resolve_installed(self):
        candidates = [
            "/opt/resolve/bin/resolve",
            "/opt/resolve/bin/resolve.sh",
            "/opt/resolve/installer",
            "/usr/bin/resolve",
            "/usr/local/bin/resolve",
        ]
        for c in candidates:
            if Path(c).exists():
                return True
        return shutil.which("resolve") is not None

    def remove_resolve_flow(self):
        if not self._resolve_installed():
            self.append_log("ℹ️ DaVinci Resolve does not appear to be installed.\n")
            self.refresh_app_state("resolve")
            return

        dialog = QMessageBox(self)
        dialog.setIcon(QMessageBox.Warning)
        dialog.setWindowTitle("Uninstall DaVinci Resolve?")
        dialog.setText("Uninstall DaVinci Resolve?")
        dialog.setInformativeText(
            "This will run the vendor uninstaller.\n\n"
            "Note: The uninstaller must run as a normal user (not root)."
        )
        dialog.setStandardButtons(QMessageBox.Cancel)
        uninstall_button = dialog.addButton("Uninstall", QMessageBox.AcceptRole)
        dialog.exec()

        if dialog.clickedButton() == uninstall_button:
            self.run_resolve_uninstaller()

    def run_resolve_uninstaller(self):
        path = "/opt/resolve/installer"
        if not Path(path).exists():
            self.append_log(f"❌ ERROR: Resolve uninstaller not found at {path}\n")
            return

        try:
            st = os.stat(path)
            if not (st.st_mode & stat.S_IXUSR):
                os.chmod(path, st.st_mode | stat.S_IXUSR)
        except Exception as e:
            self.append_log(f"❌ ERROR: could not make uninstaller executable: {e}\n")
            return

        cmd = [path]
        self.append_log("\n$ " + " ".join(cmd) + "\n")

        def worker():
            last_lines = deque(maxlen=40)

            def summarize_failure(rc):
                for line in reversed(last_lines):
                    s = line.strip()
                    if s:
                        return s
                return "Exit code {}".format(rc)

            try:
                proc = subprocess.Popen(
                    cmd,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.STDOUT,
                    text=True,
                    bufsize=1,
                )
                assert proc.stdout is not None

                for line in proc.stdout:
                    last_lines.append(line)
                    self._run_ui(self.append_log, line)

                rc = proc.wait()

                if rc == 0:
                    self._run_ui(self.append_log, "✅ Successful\n")
                    self._run_ui(self.append_log, "[exit code: {}]\n".format(rc))
                    self._run_ui(self.refresh_app_state, "resolve")
                    self._run_ui(self._prompt_reenable_selinux)
                else:
                    reason = summarize_failure(rc)
                    self._run_ui(self.append_log, "❌ Failed: {}\n".format(reason))
                    self._run_ui(self.append_log, "[exit code: {}]\n".format(rc))
            except Exception as e:
                self._run_ui(self.append_log, "❌ ERROR: {}\n".format(e))

        threading.Thread(target=worker, daemon=True).start()

    def _prompt_reenable_selinux(self):
        mode = self._selinux_getenforce()
        if mode == "enforcing":
            return

        dialog = QMessageBox(self)
        dialog.setIcon(QMessageBox.Warning)
        dialog.setWindowTitle("Re-enable SELinux enforcing?")
        dialog.setText("Re-enable SELinux enforcing?")
        dialog.setInformativeText(
            "DaVinci Resolve has been removed. You can restore SELinux enforcing.\n\n"
            "A reboot may be required for the change to fully apply."
        )
        dialog.setStandardButtons(QMessageBox.Cancel)
        enable_button = dialog.addButton("Set Enforcing (permanent)", QMessageBox.AcceptRole)
        dialog.exec()

        if dialog.clickedButton() == enable_button:
            self.run_helper_with_callback(["set_selinux_mode", "enforcing"])

    def run_local_run_installer(self, path):
        if not path or not Path(path).exists():
            self.append_log("❌ ERROR: installer path missing or not found.\n")
            return

        try:
            st = os.stat(path)
            if not (st.st_mode & stat.S_IXUSR):
                os.chmod(path, st.st_mode | stat.S_IXUSR)
        except Exception as e:
            self.append_log(f"❌ ERROR: could not make installer executable: {e}\n")
            return

        cmd = [path]
        self.append_log("\n$ SKIP_PACKAGE_CHECK=1 " + " ".join(cmd) + "\n")

        def worker():
            last_lines = deque(maxlen=40)

            def summarize_failure(rc):
                for line in reversed(last_lines):
                    s = line.strip()
                    if s:
                        return s
                return "Exit code {}".format(rc)

            try:
                env = os.environ.copy()
                env["SKIP_PACKAGE_CHECK"] = "1"
                proc = subprocess.Popen(
                    cmd,
                    stdout=subprocess.PIPE,
                    stderr=subprocess.STDOUT,
                    text=True,
                    bufsize=1,
                    env=env,
                )
                assert proc.stdout is not None

                for line in proc.stdout:
                    last_lines.append(line)
                    self._run_ui(self.append_log, line)

                rc = proc.wait()

                if rc == 0:
                    self._run_ui(self.append_log, "✅ Successful\n")
                    self._run_ui(self.append_log, "[exit code: {}]\n".format(rc))
                    self._run_ui(self.refresh_app_state, "resolve")
                else:
                    reason = summarize_failure(rc)
                    self._run_ui(self.append_log, "❌ Failed: {}\n".format(reason))
                    self._run_ui(self.append_log, "[exit code: {}]\n".format(rc))
            except Exception as e:
                self._run_ui(self.append_log, "❌ ERROR: {}\n".format(e))

        threading.Thread(target=worker, daemon=True).start()


