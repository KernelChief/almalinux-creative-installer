        elif state is True:
            self._set_req_icon(w["icon"], "ok")
            w["status"].set_text(w.get("status_enabled", "Enabled"))
            w["button"].set_sensitive(False)
        else:
            self._set_req_icon(w["icon"], "error")
            w["status"].set_text(w.get("status_disabled", "Not enabled"))
