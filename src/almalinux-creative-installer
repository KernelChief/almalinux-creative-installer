    def _set_req_icon(self, image, state):
        ctx = image.get_style_context()
        for cls in ("req-icon-ok", "req-icon-warn", "req-icon-error", "req-icon-info"):
            ctx.remove_class(cls)
        _icons = {
            "ok":       ("object-select-symbolic",      "req-icon-ok"),
            "warn":     ("dialog-warning-symbolic",     "req-icon-warn"),
            "error":    ("dialog-error-symbolic",       "req-icon-error"),
            "info":     ("dialog-information-symbolic", "req-icon-info"),
            "checking": ("content-loading-symbolic",    None),
        }
        icon_name, css_class = _icons.get(state, ("content-loading-symbolic", None))
        if not Gtk.IconTheme.get_default().has_icon(icon_name):
            icon_name = "emblem-synchronizing-symbolic"
        image.set_from_icon_name(icon_name, Gtk.IconSize.INVALID)
        image.set_pixel_size(18)
        if css_class:
