    def _set_requirement_state(self, key, state):
        w = self.repo_widgets.get(key)
        if not w:
            return
        if state is None:
            w["icon"].setText("…");  w["status"].setText("Checking…"); w["button"].setEnabled(False)
        elif state is True:
            w["icon"].setText("✅"); w["status"].setText("Enabled");   w["button"].setEnabled(False)
        else:
            w["icon"].setText("❌"); w["status"].setText("Not enabled"); w["button"].setEnabled(True)

    def _set_selinux_requirement_state(self, mode):
        w = self.repo_widgets.get("SELINUX")
        if not w:
            return
        if mode is None:
            self._set_req_icon(w["icon"], "checking")
            w["status"].set_text("Checking…")
        else:
            m = (mode or "unknown").lower()
            if m == "enforcing":
                self._set_req_icon(w["icon"], "warn")
                w["status"].set_text("Enforcing")
            elif m == "permissive":
                self._set_req_icon(w["icon"], "info")
                w["status"].set_text("Permissive")
            elif m == "disabled":
                self._set_req_icon(w["icon"], "info")
                w["status"].set_text("Disabled")
            else:
                self._set_req_icon(w["icon"], "checking")
                w["status"].set_text("Unknown")

        w["button"].set_sensitive(True)

